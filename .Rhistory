## Q2 C)
library(e1071)
svmModel <- svm(Purchase ~ LoyalCH + PriceDiff,
data = trainSet,
kernel = "linear",
cost = 1,
scale = FALSE)
w <- svmModel$coefs[1] * svmModel[1, ]
w <- svmModel$coefs[1] * svmModel[1,]
w <- t(svmModel$coefs) %*% svmModel$SV
for (i in 2:nrow(svmModel$SV)){
w <- w + svmModel$coefs[i] * svmModel$SV[i, ]
}
b <- -svmModel$rho
x <- seq(min(trainSet$LoyalCH), max(trainSet$LoyalCH), lenght = 100)
x <- seq(min(trainSet$LoyalCH), max(trainSet$LoyalCH), length = 100)
y <- -(b + w[1] * x) / w[2]
lines(x,y,col = "blue", lwd = 2)
## Q2 D)
svmPred <- predict(svmModel, testSet)
table(Predicted = svmPred, Actual = testSet$Purchase)
mean(svmPred != testSet$Purchase)
